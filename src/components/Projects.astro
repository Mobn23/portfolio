---
import type { Lang } from '../i18n/translations';
import { t } from '../i18n/translations';
interface Props { lang: Lang; }
const { lang } = Astro.props;
const i = t[lang];

const projects = [
  { title: i.proj_micro_title, desc: i.proj_micro_desc, tags: ['Microservices', 'Docker', 'Scrutinizer', 'Full-stack'], icon: '🛴', github: '' },
  { title: i.proj_devops_title, desc: i.proj_devops_desc, tags: ['Docker', 'Azure', 'Ansible', 'CI/CD', 'IaC'], icon: '⚙️', github: 'https://github.com/Mobn23/microblog' },
  { title: i.proj_moveout_title, desc: i.proj_moveout_desc, tags: ['MySQL', 'SQL', 'Scrum', 'Full-stack', 'Monolith'], icon: '📦', github: 'https://github.com/Mobn23/MoveOut' },
  { title: i.proj_web_title, desc: i.proj_web_desc, tags: ['Symfony 7', 'PHP', 'Doctrine ORM', 'Twig', 'PHPUnit', 'Scrutinizer CI', 'Docker Compose', 'Webpack', 'SCSS'], icon: '🌐', github: 'https://github.com/Mobn23/mvc-symfony7-fullstack' },
  { title: i.proj_db_title, desc: i.proj_db_desc, tags: ['Node.js', 'Express.js', 'MySQL', 'REST API', 'EJS', 'SQL', 'Stored Procedures', 'SQL Functions'], icon: '🛒', github: 'https://github.com/Mobn23/relational-db-express-node-webapp' },
];
---
<section id="projects" class="section-container">
  <h2 class="text-3xl md:text-4xl font-bold mb-12 reveal">
    <span class="gradient-text">{i.projects_title}</span>
  </h2>
  <div class="grid md:grid-cols-2 gap-6">
    {projects.map((p, idx) => (
      <div class="glass p-6 glow-border group hover:scale-[1.02] transition-all duration-300 reveal" style={`animation-delay:${idx*0.1}s`}>
        <div class="flex items-start gap-4 mb-4">
          <span class="text-3xl group-hover:animate-float">{p.icon}</span>
          <div>
            <h3 class="font-bold text-white text-lg">{p.title}</h3>
            <p class="text-gray-400 text-sm mt-1">{p.desc}</p>
          </div>
        </div>
        <div class="flex flex-wrap gap-2">
          {p.tags.map(tag => <span class="tag">{tag}</span>)}
        </div>
        {p.github ? (
          <a href={p.github} target="_blank" rel="noopener" class="inline-flex items-center gap-1 text-xs text-accent-400 hover:text-white transition-colors mt-3">
            🐙 {lang === 'sv' ? 'Visa på GitHub' : 'View on GitHub'} →
          </a>
        ) : (
          <span class="inline-flex items-center gap-1 text-xs text-gray-600 mt-3">
            🐙 {lang === 'sv' ? 'GitHub kommer snart' : 'GitHub coming soon'}
          </span>
        )}
      </div>
    ))}
  </div>
</section>
