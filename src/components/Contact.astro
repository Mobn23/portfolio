---
import type { Lang } from '../i18n/translations';
import { t } from '../i18n/translations';
interface Props { lang: Lang; }
const { lang } = Astro.props;
const i = t[lang];
---
<section id="contact" class="section-container text-center">
  <h2 class="text-3xl md:text-4xl font-bold mb-4 reveal">
    <span class="gradient-text">{i.contact_title}</span>
  </h2>
  <p class="text-gray-400 max-w-xl mx-auto mb-10 reveal">{i.contact_subtitle}</p>
  <div class="flex flex-wrap gap-4 justify-center reveal">
    <a href="mailto:mohamedbnshi@gmail.com" class="px-8 py-3 rounded-full bg-gradient-to-r from-primary-500 to-accent-500 text-white font-semibold hover:scale-105 transition-transform shadow-lg shadow-accent-500/25">
      ✉️ {i.contact_email}
    </a>
    <a href="https://www.linkedin.com/in/mohamedbnshi/" target="_blank" rel="noopener" class="px-8 py-3 rounded-full border border-white/20 text-white hover:bg-white/5 transition-all">
      💼 {i.contact_linkedin}
    </a>
    <a href="https://github.com/mobn23" target="_blank" rel="noopener" class="px-8 py-3 rounded-full border border-white/20 text-white hover:bg-white/5 transition-all">
      🐙 {i.contact_github}
    </a>
  </div>
</section>

<footer class="text-center py-8 text-gray-600 text-sm border-t border-white/5">
  <p>© 2026 Mohamed Bnshi · {i.footer_made}</p>
  <a href="https://github.com/Mobn23/portfolio" target="_blank" rel="noopener" class="text-gray-600 hover:text-accent-400 transition-colors text-xs mt-2 inline-block">
    {lang === 'sv' ? '📂 Källkod' : '📂 Source Code'}
  </a>
</footer>
