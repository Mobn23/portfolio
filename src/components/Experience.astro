---
import type { Lang } from '../i18n/translations';
import { t } from '../i18n/translations';
interface Props { lang: Lang; }
const { lang } = Astro.props;
const i = t[lang];

const experiences = [
  { title: i.exp_ericsson_title, company: i.exp_ericsson_company, date: i.exp_ericsson_date, details: [i.exp_ericsson_d1, i.exp_ericsson_d2, i.exp_ericsson_d3], tags: ['MCP', 'LLM', 'Docker', 'Kubernetes', 'CI/CD', 'Gerrit', 'Jenkins'], active: true },
  { title: i.exp_thesis_title, company: i.exp_thesis_company, date: i.exp_thesis_date, details: [i.exp_thesis_d1, i.exp_thesis_d2, i.exp_thesis_d3], tags: ['DevSecOps', 'CI/CD', 'Threat Modeling', 'Vulnerability Analysis'], active: true },
  { title: i.exp_trafikverket_title, company: i.exp_trafikverket_company, date: i.exp_trafikverket_date, details: [i.exp_trafikverket_d1, i.exp_trafikverket_d2, i.exp_trafikverket_d3], tags: ['Azure DevOps', 'PowerShell', 'JavaScript', 'CVE/CVSS', 'SBOM', 'CI/CD'], active: false },
];
---
<section id="experience" class="section-container">
  <h2 class="text-3xl md:text-4xl font-bold mb-12 reveal">
    <span class="gradient-text">{i.exp_title}</span>
  </h2>
  <div class="relative">
    <!-- Timeline line -->
    <div class="absolute left-4 md:left-8 top-0 bottom-0 w-px bg-gradient-to-b from-accent-500 via-primary-500 to-transparent"></div>
    <div class="space-y-10">
      {experiences.map((exp, idx) => (
        <div class="relative pl-12 md:pl-20 reveal" style={`animation-delay:${idx*0.15}s`}>
          <!-- Timeline dot -->
          <div class={`absolute left-2.5 md:left-6.5 top-1 w-3 h-3 rounded-full border-2 ${exp.active ? 'bg-accent-500 border-accent-400 shadow-lg shadow-accent-500/50' : 'bg-gray-600 border-gray-500'}`}></div>
          <div class="glass p-6 glow-border hover:scale-[1.01] transition-all">
            <div class="flex flex-wrap items-start justify-between gap-2 mb-3">
              <div>
                <h3 class="font-bold text-white text-lg">{exp.title}</h3>
                <p class="text-accent-400 text-sm font-mono">{exp.company}</p>
              </div>
              <span class={`tag ${exp.active ? '!bg-green-500/10 !text-green-400 !border-green-500/20' : ''}`}>{exp.date}</span>
            </div>
            <ul class="space-y-2 mb-4">
              {exp.details.map(d => (
                <li class="text-gray-300 text-sm flex gap-2">
                  <span class="text-accent-400 mt-1 shrink-0">▹</span>
                  <span>{d}</span>
                </li>
              ))}
            </ul>
            <div class="flex flex-wrap gap-2">
              {exp.tags.map(tag => <span class="tag">{tag}</span>)}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
