---
import type { Lang } from '../i18n/translations';
import { t } from '../i18n/translations';
interface Props { lang: Lang; }
const { lang } = Astro.props;
const i = t[lang];
---
<section class="min-h-screen flex items-center justify-center relative">
  <div class="section-container text-center">
    <p class="text-accent-400 font-mono text-sm mb-4 animate-fade-in">{i.hero_greeting}</p>
    <h1 class="text-5xl md:text-7xl font-extrabold mb-4 animate-fade-up">
      <span class="gradient-text">{i.hero_name}</span>
    </h1>
    <p class="text-xl md:text-2xl text-gray-300 font-light mb-6 animate-fade-up" style="animation-delay:0.2s">
      {i.hero_title}
    </p>
    <p class="max-w-2xl mx-auto text-gray-400 mb-10 animate-fade-up" style="animation-delay:0.4s">
      {i.hero_subtitle}
    </p>
    <div class="flex flex-wrap gap-4 justify-center animate-fade-up" style="animation-delay:0.6s">
      <a href="#projects" class="px-8 py-3 rounded-full bg-gradient-to-r from-primary-500 to-accent-500 text-white font-semibold hover:scale-105 transition-transform shadow-lg shadow-accent-500/25">
        {i.hero_cta}
      </a>
      <a href="#contact" class="px-8 py-3 rounded-full border border-white/20 text-white hover:bg-white/5 transition-all">
        {i.hero_contact}
      </a>
      <!-- CV Download dropdown -->
      <div class="relative group">
        <button class="px-8 py-3 rounded-full border border-white/20 text-white hover:bg-white/5 transition-all flex items-center gap-2">
          📄 {lang === 'sv' ? 'Ladda ner CV' : 'Download CV'}
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
        </button>
        <div class="absolute top-full pt-2 left-1/2 -translate-x-1/2 hidden group-hover:flex flex-col z-20">
          <div class="flex flex-col gap-1 glass p-2 min-w-[160px]">
            <a href="/Mohamed_Bnshi_CV_Software_Engineer_EN.pdf" download class="px-4 py-2 text-sm text-gray-300 hover:text-white hover:bg-white/10 rounded-lg transition-colors flex items-center gap-2">🇬🇧 English</a>
            <a href="/Mohamed_Bnshi_CV_Software_Engineer.pdf" download class="px-4 py-2 text-sm text-gray-300 hover:text-white hover:bg-white/10 rounded-lg transition-colors flex items-center gap-2">🇸🇪 Svenska</a>
          </div>
        </div>
      </div>
    </div>
    <!-- Scroll indicator -->
    <div class="absolute bottom-10 left-1/2 -translate-x-1/2 animate-bounce">
      <svg class="w-6 h-6 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/></svg>
    </div>
  </div>
</section>
