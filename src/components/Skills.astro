---
import type { Lang } from '../i18n/translations';
import { t } from '../i18n/translations';
interface Props { lang: Lang; }
const { lang } = Astro.props;
const i = t[lang];

const categories = [
  { key: 'security', icon: '🛡️', items: ['OWASP', 'CVE/CVSS', 'SBOM', 'Threat Modeling', 'Container Scanning', 'GDPR'] },
  { key: 'languages', icon: '💻', items: ['Python', 'JavaScript', 'TypeScript', 'PHP', 'SQL', 'Bash'] },
  { key: 'frameworks', icon: '⚡', items: ['React', 'Node.js', 'Express.js', 'Flask', 'Symfony 7', 'Astro', 'Tailwind CSS', 'Next.js', 'Web Components', 'REST API', 'GraphQL'] },
  { key: 'devops', icon: '🚀', items: ['Docker', 'Kubernetes', 'Azure DevOps', 'GitHub Actions', 'Jenkins', 'Gerrit', 'Ansible', 'CI/CD', 'Git', 'Networking (TCP/UDP, BGP)'] },
  { key: 'databases', icon: '🗄️', items: ['MySQL', 'PostgreSQL', 'MongoDB', 'SQLite', 'Doctrine ORM', 'Mongoose'] },
  { key: 'ai', icon: '🤖', items: ['LLM Integration', 'MCP Servers', 'AI Agents', 'Event-Driven Architecture', 'Agile/Scrum'] },
];
---
<section id="skills" class="section-container">
  <h2 class="text-3xl md:text-4xl font-bold mb-12 reveal">
    <span class="gradient-text">{i.skills_title}</span>
  </h2>
  <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
    {categories.map((cat, idx) => (
      <div class="glass p-6 glow-border hover:scale-[1.02] transition-all duration-300 reveal" style={`animation-delay:${idx*0.1}s`}>
        <div class="flex items-center gap-3 mb-4">
          <span class="text-2xl">{cat.icon}</span>
          <h3 class="font-semibold text-white">{i[`skills_${cat.key}`]}</h3>
        </div>
        <div class="flex flex-wrap gap-2">
          {cat.items.map(item => (
            <span class="tag">{item}</span>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>
