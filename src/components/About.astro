---
import type { Lang } from '../i18n/translations';
import { t } from '../i18n/translations';
interface Props { lang: Lang; }
const { lang } = Astro.props;
const i = t[lang];
---
<section id="about" class="section-container">
  <h2 class="text-3xl md:text-4xl font-bold mb-12 reveal">
    <span class="gradient-text">{i.about_title}</span>
  </h2>
  <div class="grid md:grid-cols-3 gap-8">
    <div class="md:col-span-2 space-y-4">
      <p class="text-gray-300 leading-relaxed reveal">{i.about_p1}</p>
      <p class="text-gray-300 leading-relaxed reveal">{i.about_p2}</p>
      <p class="text-gray-300 leading-relaxed reveal">{i.about_p3}</p>
    </div>
    <div class="space-y-4">
      <div class="glass p-6 reveal">
        <img src="/personal-pic.jpg" alt="Mohamed Bnshi" class="w-32 h-32 mx-auto rounded-full object-cover mb-4" />
        <div class="space-y-2 text-sm text-center">
          <p>{i.about_location}</p>
          <p>{i.about_available}</p>
          <p>{i.about_languages}</p>
        </div>
      </div>
      <div class="glass p-4 reveal">
        <p class="text-xs text-gray-500 mb-2 font-mono">{i.education_title}</p>
        <p class="text-sm font-semibold text-white">{i.education_degree}</p>
        <p class="text-sm text-gray-400">{i.education_school}</p>
        <p class="text-xs text-accent-400 mt-1">{i.education_status}</p>
      </div>
    </div>
  </div>
</section>
